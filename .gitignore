# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# data (real leads, settings)
/data/

# deploy script (contains server credentials)
deploy.sh

# deploy artifacts
deploy.tar.gz
*.tar.gz

# stray videos
video*.mp4

# Next.js trace files in public
public/**/.next/

# uploads
/public/uploads/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
